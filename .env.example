# Local dev config
DB_FILE=./qcvp.db

# Iron-session cookie secret (32+ chars). Run: openssl rand -base64 32
SESSION_SECRET=change-me-please-32-chars-minimum-xxxxxxxxxx

# ShipStation (mirror values from O:\SECRETS\claude-secrets\.env.local)
SHIPSTATION_API_KEY=
SHIPSTATION_BASE=https://api.shipstation.com/v2

# Tag name applied to a shipment when pushed via the portal
SS_TAG_NAME=Shipping

# Google Sheets (service account JSON path) — for "Pull from Google Sheet"
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Orders

# Resend (used in prod; dev logs to console)
RESEND_API_KEY=
ALERT_FROM_EMAIL=vendor-portal@quiltcomfort.com
